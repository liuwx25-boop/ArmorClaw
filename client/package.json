{
  "name": "armorclaw-client",
  "version": "1.0.0",
  "description": "ArmorClaw Desktop Client",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:proxy": "npx tsx scripts/dev-proxy-server.ts",
    "dev:all": "npx tsx scripts/dev-proxy-server.ts & vite",
    "build": "tsc && vite build && electron-builder",
    "build:mac": "tsc && vite build && electron-builder --mac",
    "build:win": "tsc && vite build && electron-builder --win",
    "build:linux": "tsc && vite build && electron-builder --linux",
    "preview": "vite preview",
    "electron:dev": "vite build --mode development && electron .",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.6.7",
    "electron-log": "^5.4.3",
    "i18next": "^23.10.0",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.5",
    "react-router-dom": "^6.22.0",
    "qrcode.react": "^4.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.2",
    "electron-builder": "^24.13.3",
    "eslint": "^8.56.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.armorclaw.client",
    "productName": "ArmorClaw",
    "directories": {
      "output": "SoftwarePackage"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "default-config.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "resources/icons/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico",
      "publisherName": "ArmorClaw"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "resources/icons/icon.png"
    },
    "dmg": {
      "title": "ArmorClaw"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ArmorClaw",
      "uninstallDisplayName": "ArmorClaw"
    },
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ]
  }
}
