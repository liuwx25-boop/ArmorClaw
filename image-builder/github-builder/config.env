# ============================================================
# ArmorClaw Image Builder - Build Configuration (Global)
# ============================================================
# All variables are read by build.sh and passed to Dockerfile
# via --build-arg. Empty variables will NOT be passed
# (Dockerfile built-in defaults will be used).

# OpenClaw source repository (GitHub primary, Gitee fallback)
OPENCLAW_REPO="https://github.com/openclaw/openclaw.git"
OPENCLAW_REPO_FALLBACK="https://gitee.com/openclaw/openclaw.git"

# OpenClaw version / branch / tag (default: main)
# Updated 2026-02-26: upgraded to v2026.2.25 stable release
OPENCLAW_VERSION="v2026.2.25"

# Full image name (with all skill pre-installed tools)
IMAGE_NAME="armorclaw:full"

# Lite image name (base only, no skill pre-installed tools)
LITE_IMAGE_NAME="armorclaw:lite"

# Base image name (intermediate artifact)
BASE_IMAGE_NAME="openclaw:base"

# Go toolchain version (passed as GO_VERSION build-arg to upstream openclaw base Dockerfile)
GO_VERSION="1.23.6"

# ============================================================
# Package registry configuration (official sources)
# ============================================================

# Go proxy (official)
GOPROXY="https://proxy.golang.org,direct"

# npm registry (official)
NPM_MIRRORS="https://registry.npmjs.org"

# pip/PyPI index (official)
PIP_MIRRORS="https://pypi.org/simple"

# ============================================================
# Docker registry configuration (for push/publish)
# ============================================================

# Default to GitHub Container Registry (ghcr.io)
# You can also use Docker Hub: docker.io/your-username/armorclaw
REGISTRY="ghcr.io"

# Remote image full name (--push will fail if empty)
REGISTRY_IMAGE=""
